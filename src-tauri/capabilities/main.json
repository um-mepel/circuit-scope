{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Allow main window to use file dialog and read/write selected files.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:read-all",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**", "$DESKTOP/**", "$DOCUMENT/**"]
    }
  ]
}
